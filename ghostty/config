font-family = Berkeley Mono
font-size = 18
cursor-style = block
background-opacity = 0.8
background-blur = 10

# theme = abc
# theme = typewriter
theme = Aura
# theme = Catppuccin Mocha
# theme = Jellybeans
# theme = Kolorit
# theme = Moonfly
# theme = Nvim Dark
# theme = TokyoNight
# theme = Tomorrow Night

custom-shader = shaders/cursor_warp.glsl
